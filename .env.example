# -----------------------------------------------------------------------
# LLM Provider configuration — copy to .env and fill in your values
# -----------------------------------------------------------------------

# --- Option A: OpenAI ---
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini

# --- Option B: Anthropic ---
# LLM_PROVIDER=anthropic
# LLM_API_KEY=sk-ant-...
# LLM_MODEL=claude-3-5-haiku-20241022

# --- Option C: AMD LLM Gateway (OpenAI-compatible) ---
# LLM_PROVIDER=openai_compat
# LLM_BASE_URL=https://llm-api.amd.com/OpenAI
# LLM_API_KEY=<your-subscription-key>
# LLM_AUTH_HEADER=Ocp-Apim-Subscription-Key
# LLM_MODEL=gpt-4o-mini

# --- Option D: Local vLLM / Ollama ---
# LLM_PROVIDER=openai_compat
# LLM_BASE_URL=http://localhost:8000
# LLM_API_KEY=none
# LLM_MODEL=llama3

# --- Optional tuning ---
# LLM_TEMPERATURE=1.0
# LLM_MAX_TOKENS=4096
# LLM_TOP_P=1.0
